{
  "manifest_version": 3,
  "name": "Copy Page Title",
  "version": "2.1",
  "description": "One-click copy of the page title.",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "iconx128.png"
  },
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_icon": {
      "16": "iconx128.png",
      "48": "iconx128.png",
      "128": "iconx128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}